model ExecutorProfile {
  /// @owner(console-internal, operator)
  id                    String   @id @default(cuid())
  /// @owner(console-internal, operator)
  projectId             String
  /// @owner(console-internal, operator)
  name                  String
  /// @owner(console-internal, operator)
  provider              String
  /// @owner(console-internal, operator)
  model                 String
  /// @owner(console-internal, operator)
